# Copy this file to .env and fill in your values
# Never commit .env to version control

# DeepSeek API — used only for RAGAS evaluation/judge role
# Get from: platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk-your-key-here

# Ollama server (default — change if you run Ollama on a different port)
# Use 127.0.0.1, not localhost: Ollama binds IPv4 only, and `localhost` resolves
# to ::1 (IPv6) first on Windows, causing slow/failed connections.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Models
PRODUCTION_MODEL=qwen3:14b-q4_K_M
VISION_MODEL=minicpm-v
EMBED_MODEL=nomic-embed-text

# Inference settings (tuned for 16GB VRAM — see config/settings.py)
CONTEXT_LENGTH=16384
KV_CACHE_TYPE=q4_0
CONTEXT_COMPRESSION_THRESHOLD=0.80

# Positional-recall (codeneedle) benchmark suite
# Corpora to run. Only http_server (~14K tokens, fits a 32K context) is shipped.
NEEDLE_CORPORA=http_server
NEEDLE_MAX_TOKENS=6000
NEEDLE_TIMEOUT_SEC=600

# Paths (leave as defaults unless you want data stored elsewhere)
DOCUMENTS_DIR=data/documents
DB_DIR=data/db
BENCHMARKS_DIR=data/benchmarks

# Ollama models directory — moved to D: to avoid filling C: drive
OLLAMA_MODELS=D:/ollama_models
